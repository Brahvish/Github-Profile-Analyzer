PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173

# GitHub Personal Access Token — raises API rate limit from 60 → 5,000 req/hour
# Generate one at: https://github.com/settings/tokens
# Required scopes: none (public data only) — just click Generate with no boxes ticked,
# or tick "public_repo" for slightly better repo data access.
GITHUB_TOKEN=your_github_pat_here
